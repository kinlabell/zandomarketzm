# ─────────────────────────────────────────
# Google Sheets (Service Account)
# ─────────────────────────────────────────
# The ID found in the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<GOOGLE_SHEET_ID>/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# From the JSON key file downloaded from Google Cloud Console
GOOGLE_PROJECT_ID=your_project_id
GOOGLE_PRIVATE_KEY_ID=your_private_key_id
# Keep the -----BEGIN/END----- markers; replace real newlines with \n
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your_client_id

# ─────────────────────────────────────────
# Email (Gmail SMTP via App Password)
# ─────────────────────────────────────────
# Enable 2-Step Verification on Gmail, then create an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_USER=contactlegaleasy@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ─────────────────────────────────────────
# WhatsApp (optional – leave blank to disable)
# ─────────────────────────────────────────
# Set to "meta" or "twilio". Leave empty to skip WhatsApp notifications.
WHATSAPP_PROVIDER=

# --- Meta / WhatsApp Cloud API ---
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WA_FROM=   # e.g. whatsapp:+14155238886
